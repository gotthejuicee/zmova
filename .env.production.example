# --- Продакшн .env для ЗМОВА (скопіюй у .env на хостингу й заповни) ---

APP_NAME="ЗМОВА"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.tld

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- База даних ---
# Найпростіший варіант — SQLite (один файл, нічого не треба налаштовувати):
DB_CONNECTION=sqlite
# Файл створюється так: touch database/database.sqlite
#
# Або MySQL (типово для Хостинг Україна — хост виду trXXXXXX.mysql.tools, НЕ localhost):
# DB_CONNECTION=mysql
# DB_HOST=trXXXXXX.mysql.tools
# DB_PORT=3306
# DB_DATABASE=trXXXXXX_zmova
# DB_USERNAME=trXXXXXX_zmova
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

# sync — заявка йде в Telegram одразу в межах запиту (без черги-воркера)
QUEUE_CONNECTION=sync
CACHE_STORE=database

MAIL_MAILER=log

# --- Telegram (заявки з форми) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Адмін Filament (створюється сидером db:seed) ---
ADMIN_NAME="Адміністратор"
ADMIN_EMAIL=admin@your-domain.tld
ADMIN_PASSWORD=
